# Basic configuration
prefix   = "fmgtest"
region   = "eu-north-1"

# Network configuration
vpc = "172.16.136.0/23"
subnets = [
  { name = "subnet-fmg1", cidr = "172.16.136.0/24", availability_zone = "eu-north-1a" },
  { name = "subnet-fmg2", cidr = "172.16.137.0/24", availability_zone = "eu-north-1b" }
]

# FortiManager configuration
fmg_vmsize       = "m5.xlarge"
fmg_license_type = "byol" # or "byol"
fmg_version      = "7.6.6"
key_name         = "your-key-pair-name"
admin_cidr       = ["0.0.0.0/0"] # Restrict this in production
fortigate_cidr   = ["0.0.0.0/0"] # Restrict this in production

# HA configuration
ha_ip                   = "public" # or "private"
ha_password             = "test1234"
fmg1_byol_serial_number = "your license serialnumber"
fmg2_byol_serial_number = "your license serialnumber"

# FortiFlex license tokens
#fmg1_byol_fortiflex_license_token = "your fortiflex token"
#fmg2_byol_fortiflex_license_token = "your fortiflex token"

# BYOL license
# fmg1_byol_license_file = "path/to/license1.lic"
# fmg2_byol_license_file = "path/to/license2.lic"
